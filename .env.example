# ─── StreamSync Environment Variables ────────────────────────────────────────
# Copy this to .env and fill in your stream keys.
# Leave a KEY blank to exclude that platform from the relay.

# Port OBS connects to (leave as 1935 unless you have a conflict)
RTMP_PORT=1935

# Port for the StreamSync dashboard web UI
DASHBOARD_PORT=3001

# Password to access the dashboard (leave blank for no auth — NOT recommended on a public server)
DASHBOARD_PASSWORD=

# ─── Tweak (Mux) ─────────────────────────────────────────────────────────────
# Your Mux stream key from tweak.mavops.org/dashboard
TWEAK_STREAM_KEY=
TWEAK_RTMP_URL=rtmp://global-live.mux.com:5222/app
TWEAK_ENABLED=true

# ─── Twitch ───────────────────────────────────────────────────────────────────
# Settings → Stream → Stream Key in Twitch
TWITCH_STREAM_KEY=
TWITCH_RTMP_URL=rtmp://live.twitch.tv/app
TWITCH_ENABLED=true

# ─── YouTube ──────────────────────────────────────────────────────────────────
# YouTube Studio → Go Live → Stream Key
YOUTUBE_STREAM_KEY=
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_ENABLED=true

# ─── TikTok ───────────────────────────────────────────────────────────────────
# TikTok LIVE Studio → Settings → Stream Key
TIKTOK_STREAM_KEY=
TIKTOK_RTMP_URL=rtmp://rtmp-push.tiktok.com/live
TIKTOK_ENABLED=true
