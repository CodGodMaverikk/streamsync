# ─── StreamSync Environment Variables ────────────────────────────────────────
# Copy this to .env and fill in your stream keys.
# Leave a KEY blank to exclude that platform from the relay.

# Port OBS connects to (leave as 1935 unless you have a conflict)
RTMP_PORT=1935

# Port for the StreamSync dashboard web UI
DASHBOARD_PORT=3001

# Password to access the dashboard (leave blank for no auth — NOT recommended on a public server)
DASHBOARD_PASSWORD=

# ─── Tweak ───────────────────────────────────────────────────────────────────
# Stream key from tweak.mavops.org/dashboard
TWEAK_STREAM_KEY=
TWEAK_RTMP_URL=rtmp://global-live.mux.com:5222/app
TWEAK_ENABLED=true
# For unified chat: your Tweak stream ID (found in the URL when you go live)
TWEAK_STREAM_ID=
TWEAK_URL=https://tweak.mavops.org

# ─── Twitch ───────────────────────────────────────────────────────────────────
TWITCH_STREAM_KEY=
TWITCH_RTMP_URL=rtmp://live.twitch.tv/app
TWITCH_ENABLED=true
# For unified chat: your Twitch channel name (e.g. yourname)
TWITCH_CHANNEL=

# ─── YouTube ──────────────────────────────────────────────────────────────────
YOUTUBE_STREAM_KEY=
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_ENABLED=true
# For unified chat: your YouTube channel ID (e.g. UCxxxxxxx) + API key
YOUTUBE_CHANNEL_ID=
YOUTUBE_API_KEY=

# ─── TikTok ───────────────────────────────────────────────────────────────────
TIKTOK_STREAM_KEY=
TIKTOK_RTMP_URL=rtmp://rtmp-push.tiktok.com/live
TIKTOK_ENABLED=true
# For unified chat: your TikTok username (e.g. yourname)
TIKTOK_USERNAME=

# ─── Kick ─────────────────────────────────────────────────────────────────────
KICK_STREAM_KEY=
KICK_RTMP_URL=rtmp://fa723fc1b171.global-contribute.live-video.net/app
KICK_ENABLED=true
# For unified chat: your Kick channel name
KICK_CHANNEL=
